SECRET_KEY=change-me-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# 4 slashes = absolute path (/data/piruetas.db). 3 slashes = relative to /app — wrong for production.
DATABASE_URL=sqlite:////data/piruetas.db
DATA_DIR=/data
PORT=8000
SECURE_COOKIES=true
# TRUST_PROXY=false
# Set to true when running behind a reverse proxy (nginx, Caddy, Traefik).
# Enables reading the real client IP from X-Forwarded-For for rate limiting.
# WARNING: Only enable if you control the proxy. Without a proxy, attackers
# can spoof X-Forwarded-For to bypass rate limiting.
WEEK_START=monday

# Demo user (optional)
DEMO_ENABLED=false
DEMO_USERNAME=demo
DEMO_PASSWORD=demo
DEMO_RESET_INTERVAL=1800
